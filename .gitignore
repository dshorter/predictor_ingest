# Python
__pycache__/
*.py[cod]
*.pyd
*.so
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
.venv/
venv/
env/
ENV/
.env
.env.*
!.env.example

# Tests and coverage
.pytest_cache/
