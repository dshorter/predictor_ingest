BEGIN:VEVENT
UID:weekly-quality-review@predictor-ingest
DTSTART;TZID=America/New_York:20260313T150000
DTEND;TZID=America/New_York:20260313T160000
RRULE:FREQ=WEEKLY;BYDAY=FR
SUMMARY:Weekly Quality Review
DESCRIPTION:Review extraction quality metrics for all domains:\n\n  python scripts/collect_metrics_gist.py\n  python scripts/collect_metrics_gist.py --domain biosafety\n  python scripts/collect_metrics_gist.py --domain film\n\nCheck:\n- Evidence fidelity rates (note: Gate A disabled for film — orphan/zero-value/high-conf still enforced)\n- Orphan endpoint counts\n- Entity resolution drift\n- Feed health / 404s\n- Trend scoring sanity
CATEGORIES:Quality
STATUS:CONFIRMED
BEGIN:VALARM
TRIGGER:-PT15M
ACTION:DISPLAY
DESCRIPTION:Quality review in 15 minutes
END:VALARM
END:VEVENT
