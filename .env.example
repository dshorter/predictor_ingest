# Copy this file to .env on the server and fill in real values.
# .env is gitignored — never commit it.

# --- Required ---
ANTHROPIC_API_KEY=your-key-here

# Primary extraction + synthesis model. Use alias form (no date suffix) so it
# never breaks on version deprecation. All pipeline scripts read this env var;
# hardcoded fallbacks are only a last resort for sandboxes without .env.
PRIMARY_MODEL=claude-sonnet-4-6

# Narrative/trending model (cheaper, faster).
NARRATIVE_MODEL=claude-haiku-4-5-20251001

# Understudy model for shadow-mode comparison.
UNDERSTUDY_MODEL=gpt-5-nano

# --- Optional ---
# PREDICTOR_DOMAIN=film        # default domain if --domain flag is omitted
# OPENAI_API_KEY=              # needed for UNDERSTUDY_MODEL if using OpenAI models
# BSKY_HANDLE=                 # Bluesky handle for social ingestion
