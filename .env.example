# Copy this file to .env on the server and fill in real values.
# .env is gitignored — never commit it.

# --- Required ---
ANTHROPIC_API_KEY=your-key-here

# Primary extraction + synthesis model. Single source of truth.
# All pipeline scripts read this; hardcoded fallbacks are only a last resort.
PRIMARY_MODEL=claude-sonnet-4-6-20260218

# Narrative/trending model (cheaper, faster).
NARRATIVE_MODEL=claude-haiku-4-5-20251001

# --- Optional ---
# PREDICTOR_DOMAIN=film        # default domain if --domain flag is omitted
# OPENAI_API_KEY=              # only needed if using OpenAI models for synthesis/disambig
